<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-task-event-messages" author="codex">
        <createTable tableName="task_event_messages">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_task_event_messages"/>
            </column>
            <column name="topic" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="partition_id" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="message_offset" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="message_key" type="VARCHAR(255)"/>
            <column name="event_type" type="VARCHAR(64)"/>
            <column name="task_id" type="BIGINT"/>
            <column name="event_timestamp" type="TIMESTAMP(6)"/>
            <column name="user_id" type="BIGINT"/>
            <column name="payload" type="CLOB">
                <constraints nullable="false"/>
            </column>
            <column name="received_at" type="TIMESTAMP(6)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="task_event_messages"
                columnNames="topic, partition_id, message_offset"
                constraintName="uq_task_event_messages_kafka_position"/>

        <createIndex tableName="task_event_messages" indexName="idx_task_event_messages_task">
            <column name="task_id"/>
        </createIndex>

        <createIndex tableName="task_event_messages" indexName="idx_task_event_messages_event_type">
            <column name="event_type"/>
        </createIndex>

        <createIndex tableName="task_event_messages" indexName="idx_task_event_messages_received_at">
            <column name="received_at"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
