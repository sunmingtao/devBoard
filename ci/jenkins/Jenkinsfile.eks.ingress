pipeline {
    agent any

    options {
        timestamps()
        disableConcurrentBuilds()
    }

    parameters {
        string(name: 'AWS_REGION', defaultValue: 'ap-southeast-2', description: 'AWS region')
        string(name: 'CLUSTER_NAME', defaultValue: 'devboard-dev-eks', description: 'EKS cluster name')
        string(name: 'APP_URL', defaultValue: 'https://www.smtdevboard.com', description: 'Application URL')
    }

    environment {
        NAMESPACE = 'devboard'
        INGRESS_NAME = 'devboard-ingress'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Verify Tools') {
            steps {
                sh '''
                    set -e
                    aws --version
                    kubectl version --client
                    curl --version
                '''
            }
        }

        stage('Configure kubeconfig') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'aws-devboard-terraform',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    )
                ]) {
                    sh """
                        set -eux
                        export AWS_DEFAULT_REGION=${params.AWS_REGION}

                        aws eks update-kubeconfig \
                          --region ${params.AWS_REGION} \
                          --name ${params.CLUSTER_NAME}

                        kubectl get nodes
                        kubectl get svc -n ${env.NAMESPACE}
                    """
                }
            }
        }

        stage('Wait for ALB') {
            steps {
                withCredentials([
                    usernamePassword(
                        credentialsId: 'aws-devboard-terraform',
                        usernameVariable: 'AWS_ACCESS_KEY_ID',
                        passwordVariable: 'AWS_SECRET_ACCESS_KEY'
                    )
                ]) {
                    sh """
                        set -eux
                        export AWS_DEFAULT_REGION=${params.AWS_REGION}

                        for i in \$(seq 1 30); do
                          ALB_HOST=\$(kubectl get ingress ${env.INGRESS_NAME} -n ${env.NAMESPACE} -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' || true)

                          if [ -n "\$ALB_HOST" ]; then
                            echo "ALB_HOST=\$ALB_HOST"
                            exit 0
                          fi

                          echo "Waiting for ALB hostname..."
                          sleep 10
                        done

                        echo "ERROR: ALB hostname was not assigned"
                        kubectl describe ingress ${env.INGRESS_NAME} -n ${env.NAMESPACE} || true
                        exit 1
                    """
                }
            }
        }

        stage('Verify HTTPS') {
            steps {
                sh """
                    set -eux

                    for i in \$(seq 1 30); do
                        getent hosts www.smtdevboard.com || true

                        if curl -fsS ${params.APP_URL}/api/health; then
                            echo "Health check passed"
                            exit 0
                        fi

                        echo "Waiting for DNS/ALB/application readiness... attempt \$i/30"
                        sleep 10
                    done

                    echo "ERROR: Health check failed after retries"
                    curl -Iv ${params.APP_URL} || true
                    exit 1
                """
            }
        }
    }

    post {
        success {
            echo 'EKS ingress verification completed successfully.'
        }

        failure {
            echo 'EKS ingress verification failed. Check Argo CD Ingress, ALB controller, Route53, and HTTPS.'
        }
    }
}
